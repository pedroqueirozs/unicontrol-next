generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// ENUMS
// =============================================

// Os três papéis possíveis de um usuário dentro de uma empresa.
// "admin" tem acesso total. Os demais têm acesso restrito conforme RN-18.
enum Role {
  admin
  expedicao
  vendas
}

// Tipo de transportadora: empresa com dados completos ou entrega simples (só nome).
enum CarrierType {
  empresa  // Braspress, Correios, empresa de ônibus etc.
  simples  // Retirada na empresa, Táxi, Entrega própria etc.
}

// =============================================
// EMPRESA
// =============================================

// Representa uma empresa cadastrada no sistema.
// Por enquanto teremos apenas uma, mas a estrutura já está pronta
// para multi-tenant: cada dado de negócio vai ter um companyId.
model Company {
  id        String  @id @default(cuid())
  name      String
  street    String?
  district  String?
  city      String?
  state     String?
  zip       String?
  phone     String?
  whatsapp  String?
  logoUrl   String?

  createdAt DateTime @default(now())

  users     User[]
  invites   Invite[]
  clients   Client[]
  suppliers Supplier[]
  carriers  Carrier[]
}

// =============================================
// AUTENTICAÇÃO — NextAuth v5 + campos do app
// =============================================

// Usuário do sistema. Combina os campos obrigatórios do NextAuth
// com os campos próprios do UniControl (role e companyId).
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hash bcrypt — só usado no login por credenciais

  role      Role   @default(expedicao)
  companyId String

  company  Company   @relation(fields: [companyId], references: [id])
  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Necessário pelo NextAuth para armazenar tokens de provedores OAuth.
// Mesmo sem usar OAuth agora, o adapter exige essa tabela.
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

// Sessões de usuário armazenadas no banco.
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tokens de verificação de e-mail (necessário pelo adapter do NextAuth).
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// =============================================
// CONVITES
// =============================================

// Um convite gerado pelo admin para adicionar um novo membro.
// O admin gera o link, envia para o funcionário, e ele se cadastra
// usando o token da URL (/register?token=xxx).
model Invite {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  role      Role
  used      Boolean  @default(false)
  expiresAt DateTime

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
}

// =============================================
// CADASTROS
// =============================================

// Cliente cadastrado no sistema.
// Fonte de dados central para Mercadorias, Endereços e Pendências de Clientes.
// Código gerado automaticamente (C-001, C-002...) — não inserido manualmente (RN-20).
model Client {
  id                String  @id @default(cuid())
  code              String  // C-001, C-002... gerado automaticamente
  name              String
  cnpj              String  // CNPJ ou CPF com máscara — obrigatório (RN-20)
  stateRegistration String? // Inscrição Estadual — null = Isento
  street            String?
  number            String?
  complement        String?
  neighborhood      String?
  city              String?
  state             String?
  zipCode           String?
  phone             String?
  email             String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// Fornecedor cadastrado no sistema.
// Estrutura idêntica à de clientes — código no formato F-001, F-002...
model Supplier {
  id                String  @id @default(cuid())
  code              String  // F-001, F-002... gerado automaticamente
  name              String
  cnpj              String  // CNPJ ou CPF com máscara — obrigatório (RN-20)
  stateRegistration String? // Inscrição Estadual — null = Isento
  street            String?
  number            String?
  complement        String?
  neighborhood      String?
  city              String?
  state             String?
  zipCode           String?
  phone             String?
  email             String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// Transportadora cadastrada pela empresa.
// type = "empresa": dados completos (CNPJ, endereço, IE, contato, URL rastreio).
// type = "simples": só nome — para Retirada na empresa, Táxi, Entrega própria etc.
model Carrier {
  id                String      @id @default(cuid())
  type              CarrierType @default(simples)
  name              String
  cnpj              String?
  stateRegistration String?
  street            String?
  number            String?
  complement        String?
  neighborhood      String?
  city              String?
  state             String?
  zipCode           String?
  phone             String?
  email             String?
  trackingUrl       String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}
